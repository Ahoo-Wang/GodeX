{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Shanghai",
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": false },
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group @logtape logging packages (co-released upstream)",
      "matchPackagePatterns": ["^@logtape/"],
      "groupName": "logtape"
    },
    {
      "description": "Group @ahoo-wang/fetcher ecosystem packages",
      "matchPackagePatterns": ["^@ahoo-wang/fetcher"],
      "groupName": "fetcher-ecosystem"
    },
    {
      "description": "Group TypeScript type definitions",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "types"
    },
    {
      "description": "Group VitePress wiki toolchain updates",
      "matchFileNames": ["wiki/package.json"],
      "groupName": "vitepress-wiki"
    },
    {
      "description": "Use ci(deps) prefix for GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "semanticCommitType": "ci"
    },
    {
      "description": "Ignore platform-specific binary packages; versions are synced via scripts/version.ts",
      "matchPackagePatterns": ["^@ahoo-wang/godex-"],
      "enabled": false
    }
  ]
}
